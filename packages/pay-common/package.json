{
  "name": "@rozoai/intent-common",
  "version": "0.1.22-beta.3",
  "description": "Intent Pay shared types and utilities",
  "homepage": "https://github.com/RozoAI/intent-pay",
  "license": "BSD-2-Clause",
  "author": "RozoAI",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm run test && tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "test": "tape -r ts-node/register/transpile-only test/**/*.test.ts",
    "lint": "pnpm run lint:deps && pnpm run lint:style",
    "lint:deps": "npx depcheck --ignores @tsconfig/node20,@types/tape,ts-node",
    "lint:style": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "publish:beta": "pnpm publish --no-git-checks --tag beta",
    "publish:latest": "pnpm publish --no-git-checks --tag latest"
  },
  "dependencies": {
    "@scure/base": "^1.2.4",
    "@solana/web3.js": "^1.98.4",
    "@stellar/stellar-sdk": "^14.4.3",
    "viem": "^2.23.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "@types/tape": "^5.6.0",
    "depcheck": "^1.4.3",
    "oxfmt": "latest",
    "oxlint": "latest",
    "tape": "^5.6.3",
    "ts-node": "^10.9.2",
    "typescript": "5.5.2"
  }
}
