{
  "name": "@rozoai/intent-pay",
  "version": "0.1.38-beta.5",
  "private": false,
  "description": "Seamless crypto payments. Onboard users from any chain, any coin into your app with one click.",
  "keywords": [
    "blockchain",
    "crypto",
    "ens",
    "ethereum",
    "family",
    "hooks",
    "pay",
    "payment",
    "react",
    "react-hook",
    "rozoai"
  ],
  "homepage": "https://github.com/RozoAI/intent-pay",
  "license": "BSD-2-Clause",
  "author": "RozoAI",
  "files": [
    "build",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/src/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "scripts": {
    "start": "rollup --config rollup.config.js -w",
    "dev": "rollup --config rollup.config.js -w",
    "build": "rollup --config rollup.config.js",
    "prepublishOnly": "pnpm run build",
    "lint": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "release": "bumpp",
    "publish:beta": "node scripts/release.js beta",
    "publish:latest": "node scripts/release.js latest"
  },
  "dependencies": {
    "@reown/appkit": "^1.7.0",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rozoai/intent-common": "0.1.26-beta.1",
    "@solana/spl-memo": "^0.2.5",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/web3.js": "^1.98.4",
    "@trpc/client": "^11.0.0-next-beta.318",
    "@trpc/server": "^11.0.0-next-beta.318",
    "@walletconnect/sign-client": "^2.22.3",
    "@worldcoin/minikit-js": "^1.9.7",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "detect-browser": "^5.3.0",
    "framer-motion": "^11.11.4",
    "pusher-js": "^8.4.0",
    "qrcode": "^1.5.4",
    "react-transition-state": "^1.1.4",
    "react-use-measure": "^2.1.1",
    "resize-observer-polyfill": "^1.5.1",
    "styled-components": "^5.3.5"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@types/node": "^20.14.12",
    "@types/qrcode": "^1.4.2",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/styled-components": "^5.1.25",
    "@walletconnect/types": "^2.22.3",
    "oxfmt": "latest",
    "oxlint": "latest",
    "rollup": "^3.29.5",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-visualizer": "^6.0.5"
  },
  "peerDependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@stellar/stellar-sdk": "^14.2.0",
    "@tanstack/react-query": ">=5.0.0",
    "posthog-js": "^1.0.0",
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x",
    "viem": "2.x",
    "wagmi": "2.x"
  },
  "peerDependenciesMeta": {
    "@worldcoin/minikit-js": {
      "optional": true
    },
    "posthog-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=12.4"
  }
