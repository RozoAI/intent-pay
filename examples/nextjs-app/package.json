{
  "name": "examples/nextjs-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint src/ app/ components/ lib/",
    "format": "oxfmt src/ app/ components/ lib/ && prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "oxfmt --check src/ app/ components/ lib/ && prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node e2e/run.cjs",
    "setup-wallets": "node_modules/.bin/chainwright e2e/wallet-setup --wallets metamask phantom",
    "test:e2e:mocked": "SKIP_ENV_VALIDATION=1 node e2e/run.cjs --mocked",
    "test:e2e:list": "node e2e/run.cjs --list",
    "test:e2e:ui": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@rozoai/intent-common": "0.1.24-beta.1",
    "@rozoai/intent-pay": "0.1.37-beta.1",
    "@stellar/stellar-sdk": "^14.6.1",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.378.1",
    "radix-ui": "^1.4.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-syntax-highlighter": "^15.6.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.23.2",
    "wagmi": "^2.14.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "chainwright": "^0.10.9",
    "oxfmt": "latest",
    "oxlint": "latest",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
