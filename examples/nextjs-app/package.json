{
  "name": "examples/nextjs-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint src/ app/ components/ lib/",
    "format": "oxfmt src/ app/ components/ lib/ && prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "oxfmt --check src/ app/ components/ lib/ && prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test:e2e": "node_modules/.bin/playwright test --config e2e/playwright.config.ts",
    "test:e2e:mocked": "SKIP_ENV_VALIDATION=1 node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=mocked",
    "test:e2e:checkout-api": "SKIP_ENV_VALIDATION=1 E2E_REAL_API=true node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=mocked --grep \"Create Payment API flow|manual Payment ID|modal \\\\(via Create Payment\\\\)\"",
    "test:e2e:evm-to-stellar": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=evm-to-stellar --no-deps",
    "test:e2e:stellar-to-evm": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=stellar-to-evm --no-deps",
    "test:e2e:stellar-to-solana": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=stellar-to-solana --no-deps",
    "test:e2e:solana-to-stellar": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=solana-to-stellar --no-deps",
    "test:e2e:solana-to-evm": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=solana-to-evm --no-deps",
    "test:e2e:evm-to-solana": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=evm-to-solana --no-deps",
    "test:e2e:checkout-evm-to-stellar": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=checkout-evm-to-stellar --no-deps",
    "test:e2e:checkout-evm-to-solana": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=checkout-evm-to-solana --no-deps",
    "test:e2e:checkout-stellar-to-evm": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=checkout-stellar-to-evm --no-deps",
    "test:e2e:checkout-stellar-to-solana": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=checkout-stellar-to-solana --no-deps",
    "test:e2e:checkout-solana-to-stellar": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=checkout-solana-to-stellar --no-deps",
    "test:e2e:checkout-solana-to-evm": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=checkout-solana-to-evm --no-deps",
    "test:e2e:merchant-evm": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=merchant-evm --no-deps",
    "test:e2e:merchant-solana": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=merchant-solana --no-deps",
    "test:e2e:merchant-stellar": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=merchant-stellar --no-deps",
    "test:e2e:deposit-stellar-to-evm": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=deposit-stellar-to-evm --no-deps",
    "test:e2e:deposit-stellar-to-solana": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=deposit-stellar-to-solana --no-deps",
    "test:e2e:deposit-evm-to-stellar": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=deposit-evm-to-stellar --no-deps",
    "test:e2e:deposit-evm-to-solana": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=deposit-evm-to-solana --no-deps",
    "test:e2e:deposit-solana-to-stellar": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=deposit-solana-to-stellar --no-deps",
    "test:e2e:deposit-solana-to-evm": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --project=deposit-solana-to-evm --no-deps",
    "test:e2e:ui": "node_modules/.bin/playwright test --config e2e/playwright.config.ts --ui",
    "setup-wallets": "node_modules/.bin/chainwright e2e/wallet-setup --wallets metamask phantom"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@rozoai/intent-common": "0.1.25",
    "@rozoai/intent-pay": "0.1.38-beta.4",
    "@stellar/stellar-sdk": "^14.6.1",
    "@tanstack/react-query": "^5.0.0",
    "@web3icons/react": "^4.1.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.378.1",
    "radix-ui": "^1.4.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-syntax-highlighter": "^15.6.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.23.2",
    "wagmi": "^2.14.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "chainwright": "^0.10.9",
    "oxfmt": "latest",
    "oxlint": "latest",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
