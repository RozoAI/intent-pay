# Real-wallet mainnet E2E (chroma + MetaMask).
# Copy to .env.e2e (gitignored) and fill in before running:
#   pnpm test:e2e:mainnet
#
# WARNING: this drives a real MetaMask extension against MAINNET with REAL funds.
# Never commit this file. Never use a wallet holding more than test amounts.

# 12/24-word seed phrase for the MetaMask account that will sign the tx.
E2E_SEED_PHRASE=

# Password used to encrypt the MetaMask vault inside the test browser profile.
# Any string is fine — not your wallet's real password, just a local secret
# Chainwright uses to unlock the extension during the test run.
E2E_WALLET_PASSWORD=

# Sender EVM address (must match the account derived from E2E_SEED_PHRASE)
E2E_SENDER_ADDRESS=0xdC4313EfB37836615d820F38A6016EE76598887B

# Destination Stellar address (G... pubkey)
E2E_DEST_STELLAR_ADDRESS=GDATMUNQEPN4TPETV47LAKGJELK4DUHHDRPMGD3K5LOHUPXX2DI623KY

# Amount of USDC to send (human units, e.g. "0.2")
E2E_AMOUNT=0.2

# Source wallet option testid (chainwright spec only): rozopay-option-{chainId}-{tokenAddress}
# Default below is Base USDC.
E2E_SOURCE_OPTION_ID=8453-0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
