# ════════════════════════════════════════════════════════════════════════════
# RozoPay payment-flow E2E — REAL FUNDS, MAINNET.
#
# Copy to .env.e2e and fill in. NEVER commit. Use throwaway wallets that hold
# only small test amounts.
#
# Wallets are REUSABLE across flows — each is a SOURCE one way, a DESTINATION
# the other:
#   EVM → Stellar : source = EVM wallet,       destination = a Stellar wallet
#   Stellar → EVM : source = a Stellar wallet, destination = EVM wallet
#   (Solana flows: coming later)
#
# Run a flow:
#   pnpm test:e2e:evm-to-stellar
#   pnpm test:e2e:stellar-to-evm
# ════════════════════════════════════════════════════════════════════════════

# USDC amount to send (human units) — applies to every flow.
E2E_AMOUNT=0.02

# ─── EVM wallet (MetaMask, driven by chainwright) ─────────────────────────────
# Seed phrase imported into the cached MetaMask profile (run: pnpm setup-wallets).
E2E_EVM_SEED_PHRASE=""
# Local-only password to unlock the MetaMask vault in the test profile.
# Any string — not a real wallet password.
E2E_EVM_WALLET_PASSWORD=""
# This wallet's public address — DESTINATION when paying to an EVM chain.
E2E_EVM_ADDRESS=""
# Optional: source token to pay FROM (rozopay-option-{chainId}-{token}).
# Defaults to Base USDC if unset.
# E2E_EVM_SOURCE_OPTION_ID=8453-0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ─── Stellar wallet (reusable; in-page headless signer) ───────────────────────
# A single { SECRET, ADDRESS } pair:
#   - SECRET (S...) signs when Stellar is the SOURCE  → needs funds + trustline.
#   - ADDRESS (G...) receives when Stellar is the DESTINATION → needs a trustline.
#
# The test injects the SECRET into the app at runtime, so you do NOT need to set
# any NEXT_PUBLIC_ secret by hand. Must be funded and have a USDC trustline.
E2E_STELLAR_SECRET=""
E2E_STELLAR_ADDRESS=""

# ─── Solana wallet (coming later) ─────────────────────────────────────────────
# E2E_SOLANA_SECRET=...
# E2E_SOLANA_ADDRESS=...
